@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: Georgia, serif; background: linear-gradient(135deg, rgb(44, 24, 16) 0%, rgb(26, 15, 8) 100%); color: rgb(212, 175, 55); overflow-x: hidden; min-height: 100vh; padding: 20px; }

.paper { max-width: 1000px; margin: 0px auto; background: linear-gradient(135deg, rgb(245, 230, 211) 0%, rgb(232, 212, 184) 100%); padding: 40px 40px 50px; border-radius: 3px; box-shadow: rgba(0, 0, 0, 0.8) 0px 20px 60px, rgba(255, 255, 255, 0.3) 0px 1px 0px inset, rgba(0, 0, 0, 0.1) 0px -2px 5px inset; position: relative; border: 2px solid rgb(201, 169, 97); }

.paper::before { content: ""; position: absolute; inset: 0px; background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(139, 69, 19, 0.1) 2px, rgba(139, 69, 19, 0.1) 4px), repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(139, 69, 19, 0.05) 2px, rgba(139, 69, 19, 0.05) 4px); pointer-events: none; border-radius: 3px; }

.seal { display: inline-flex; width: 80px; height: 80px; background: linear-gradient(135deg, rgb(201, 16, 46), rgb(128, 0, 32)); border-radius: 50%; margin-bottom: 20px; box-shadow: rgba(0, 0, 0, 0.4) 0px 4px 8px, rgba(255, 255, 255, 0.3) 0px 1px 0px inset; align-items: center; justify-content: center; color: rgb(245, 230, 211); font-weight: bold; text-align: center; font-size: 12px; }

.header { text-align: center; margin-bottom: 30px; border-bottom: 2px solid rgb(139, 69, 19); padding-bottom: 20px; }

.header h1 { font-size: 28px; color: rgb(139, 69, 19); text-shadow: rgba(255, 255, 255, 0.3) 1px 1px 2px; margin-bottom: 5px; letter-spacing: 2px; }

.header p { color: rgb(112, 66, 20); font-style: italic; font-size: 14px; }

.date-stamp { background: rgba(201, 169, 97, 0.3); border: 1px dashed rgb(201, 169, 97); padding: 10px; border-radius: 3px; text-align: right; font-size: 12px; color: rgb(112, 66, 20); margin-bottom: 20px; }

.letter-content { font-size: 16px; line-height: 1.8; color: rgb(74, 55, 40); margin-bottom: 20px; text-align: justify; }

.puzzle-block { background: rgba(0, 0, 0, 0.05); border-left: 4px solid rgb(201, 16, 46); padding: 20px; margin: 20px 0px; border-radius: 3px; }

.puzzle-title { color: rgb(201, 16, 46); font-weight: bold; margin-bottom: 10px; font-size: 14px; }

.options { display: flex; flex-direction: column; gap: 10px; margin: 15px 0px; }

.btn-option { background: rgb(201, 16, 46); color: rgb(245, 230, 211); border: 1px solid rgb(139, 0, 0); padding: 12px 20px; border-radius: 3px; cursor: pointer; font-family: Georgia, serif; font-size: 14px; transition: 0.3s; text-align: left; }

.btn-option:hover { background: rgb(139, 0, 0); box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 8px; transform: translateX(5px); }

.feedback { margin-top: 15px; padding: 12px; border-radius: 3px; font-style: italic; display: none; }

.feedback.show { display: block; }

.feedback.correct-msg { background: rgba(45, 80, 22, 0.2); color: rgb(45, 80, 22); border: 1px solid rgb(45, 80, 22); }

.feedback.wrong-msg { background: rgba(139, 0, 0, 0.2); color: rgb(139, 0, 0); border: 1px solid rgb(139, 0, 0); }

.progress { background: rgba(0, 0, 0, 0.1); padding: 15px; border-radius: 3px; margin-top: 20px; text-align: center; color: rgb(112, 66, 20); font-size: 14px; }

.progress-bar { background: rgba(0, 0, 0, 0.1); height: 8px; border-radius: 4px; margin-top: 8px; overflow: hidden; }

.progress-fill { background: linear-gradient(90deg, rgb(201, 16, 46), rgb(45, 80, 22)); height: 100%; width: 0px; transition: width 0.3s; }

.result-block { background: rgba(0, 0, 0, 0.1); padding: 20px; border-radius: 3px; margin-top: 20px; text-align: center; color: rgb(74, 55, 40); display: none; }

.result-block.show { display: block; }

.result-block h2 { color: rgb(201, 16, 46); margin-bottom: 10px; font-size: 20px; }

.signature { margin-top: 30px; text-align: center; font-style: italic; color: rgb(112, 66, 20); font-size: 14px; }

.stamp-image { display: inline-block; width: 60px; height: 80px; background: linear-gradient(135deg, rgb(245, 230, 211), rgb(232, 212, 184)); border: 2px dashed rgb(139, 69, 19); margin: 10px 5px; padding: 5px; text-align: center; font-size: 11px; color: rgb(139, 69, 19); font-weight: bold; }

.next-btn { background: rgb(45, 80, 22); color: rgb(245, 230, 211); border: 1px solid rgb(26, 48, 9); padding: 12px 30px; border-radius: 3px; cursor: pointer; font-family: Georgia, serif; font-size: 14px; margin-top: 15px; transition: 0.3s; }

.next-btn:hover { background: rgb(26, 48, 9); box-shadow: rgba(0, 0, 0, 0.3) 0px 4px 8px; }

.section-title { margin: 30px 0px 10px; font-size: 18px; text-transform: uppercase; letter-spacing: 3px; color: rgb(139, 69, 19); border-bottom: 2px solid rgb(139, 69, 19); padding-bottom: 6px; }

.collection-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-top: 10px; }

.collect-card { background: rgba(255, 255, 255, 0.6); border-radius: 4px; padding: 10px; border: 1px solid rgb(201, 169, 97); }

.collect-card h4 { margin-bottom: 4px; font-size: 14px; color: rgb(139, 69, 19); }

.collect-card p { font-size: 13px; color: rgb(74, 55, 40); }

.collect-card.rare { background: rgba(212, 175, 55, 0.18); border-color: rgb(212, 175, 55); }

.reg-form { margin-top: 10px; background: rgba(255, 255, 255, 0.7); padding: 15px; border-radius: 4px; border: 1px solid rgb(201, 169, 97); }

.field { margin-bottom: 10px; }

.field label { display: block; font-size: 13px; margin-bottom: 4px; color: rgb(74, 55, 40); }

.field input, .field select { width: 100%; padding: 8px; border-radius: 4px; border: 1px solid rgb(201, 188, 162); font-size: 14px; font-family: Georgia, serif; }

.field.checkbox label { display: flex; align-items: flex-start; gap: 6px; font-size: 12px; }

.field.checkbox input { width: auto; margin-top: 3px; }

.btn-submit { background: rgb(201, 16, 46); color: rgb(245, 230, 211); border: 1px solid rgb(139, 0, 0); padding: 10px 20px; border-radius: 3px; cursor: pointer; font-family: Georgia, serif; font-size: 14px; margin-top: 5px; }

.btn-submit:hover { background: rgb(139, 0, 0); }

.reg-note { font-size: 11px; color: rgb(112, 66, 20); margin-top: 6px; }

.reg-result { margin-top: 8px; font-size: 13px; color: rgb(45, 80, 22); }

@media (max-width: 700px) {
  .paper { padding: 28px 18px 32px; }
  .header h1 { font-size: 22px; }
  .letter-content { font-size: 14px; }
}
